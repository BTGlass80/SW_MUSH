# ── Database ──────────────────────────────────────────────────
# Never commit live game data. Delete sw_mush.db from tracking with:
#   git rm --cached sw_mush.db && git commit -m "remove db from tracking"
sw_mush.db
sw_mush.db-shm
sw_mush.db-wal
*.db-shm
*.db-wal

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
dist/
build/

# ── Lore-ingestion scratch (review files + logs; canonical home is lore.yaml) ──
ingest_review/
.eggs/

# ── Virtual environment ───────────────────────────────────────
venv/
.venv/
env/
.env/

# ── Node / VSCode-extension deps ──────────────────────────────
# node_modules is pulled in by the Claude Code VSCode extension's npm install.
# It must never be committed (~25 MB of deps) and must never reach the AI upload
# zip (make_upload_zip.ps1 drives its file list from git, so this line keeps the
# ~1,500 dep files out automatically). package.json / package-lock.json DO ship.
node_modules/

# ── OS / Editor ───────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/

# ── Secrets / Keys (never commit these) ──────────────────────
*.key
*.pem
secrets.yaml
config.local.yaml
token_secret.key  # persisted HMAC login-token secret (server/api.py); also matched by *.key

# WEG sourcebook PDFs + text sidecars — local only (size/copyright)
docs/sourcebooks/

# Claude Code local settings — per-machine (holds the unattended bypassPermissions mode); never commit
.claude/settings.local.json

# Nano map-paint candidate batches — generated test output; only the SELECTED
# substrate (static/maps/*_substrate.png) is committed, never the candidate runs.
static/tools/batches/

# Playwright E2E screenshots + server log — regenerated on every run, never committed
tests/e2e/_screens/
{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Committed, always-on. The 'deny' list is the hard safety backstop (enforced even under bypassPermissions). The 'allow' list reduces prompts when running in a prompting mode (default/plan). Unattended auto-run lives in the gitignored .claude/settings.local.json (defaultMode: bypassPermissions) so it stays on Brian's machine only.",
  "permissions": {
    "allow": [
      "Bash(python -m pytest:*)",
      "Bash(python -m py_compile:*)",
      "Bash(python -c:*)",
      "Bash(python tools/:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git branch:*)",
      "Bash(git switch:*)",
      "Bash(git stash list:*)",
      "Bash(git check-ignore:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(echo:*)"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(git push)",
      "Bash(git reset --hard:*)",
      "Bash(git checkout:*)",
      "Bash(git clean:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(rm -rf:*)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(run_all_tests.bat)",
      "Bash(./run_all_tests.bat)",
      "PowerShell(git push:*)",
      "PowerShell(git reset --hard:*)",
      "PowerShell(git merge:*)",
      "PowerShell(git rebase:*)",
      "PowerShell(Remove-Item:*)",
      "PowerShell(rm -rf:*)"
    ]
  }
}
